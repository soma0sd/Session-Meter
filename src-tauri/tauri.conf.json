{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SessionMeter",
  "version": "0.4.5",
  "identifier": "sd.soma0.sessionmeter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "url": "settings.html",
        "title": "SessionMeter",
        "decorations": false,
        "width": 460,
        "height": 620,
        "minWidth": 380,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "widget",
        "url": "widget.html",
        "title": "SessionMeter Widget",
        "width": 252,
        "height": 150,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "stats",
        "url": "stats.html",
        "title": "SessionMeter - Statistics",
        "decorations": false,
        "width": 700,
        "height": 580,
        "minWidth": 520,
        "minHeight": 440,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "news",
        "url": "news.html",
        "title": "SessionMeter - What's New",
        "decorations": false,
        "width": 460,
        "height": 520,
        "minWidth": 360,
        "minHeight": 360,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "style",
        "url": "style.html",
        "title": "SessionMeter - Widget Style",
        "decorations": false,
        "width": 540,
        "height": 640,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "menu",
        "url": "menu.html",
        "title": "SessionMeter Menu",
        "width": 196,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "resources": {
      "icons/icon.ico": "icon.ico"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/soma0sd/Session-Meter/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3QUNCMTMzRTU2NUQ0REEKUldUYTFHWGxNN0dzdDhINVhEVXlVR29vUVVKZ2cydjVCMHBYVlNTK2hXOWtIN3BKWFlDUzZDSWIK"
    }
  }
}

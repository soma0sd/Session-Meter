{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "titlebar",
  "description": "Frameless custom title-bar controls for the settings, stats, and style windows.",
  "windows": ["settings", "stats", "style"],
  "permissions": [
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-unminimize"
  ]
}
